<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ggg_rental.RentalSerialImportDialog">
        <Dialog title="'Import Serial Numbers'" size="'md'" close="props.close">
            <div class="p-3">
                <t t-if="!state.result">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Select CSV file:</label>
                        <input type="file"
                               class="form-control"
                               accept=".csv"
                               t-on-change="onFileChange"/>
                        <div class="form-text">
                            Use the "Download Serial Template" button to get the correct
                            CSV format (<code>sap_article_code</code>, <code>serial_number</code>).
                        </div>
                    </div>
                    <div class="text-end">
                        <button class="btn btn-secondary me-2" t-on-click="props.close">
                            Cancel
                        </button>
                        <button class="btn btn-primary"
                                t-on-click="onUpload"
                                t-att-disabled="state.uploading or !state.fileName">
                            <t t-if="state.uploading">
                                <i class="fa fa-spinner fa-spin me-1"/>Importing...
                            </t>
                            <t t-else="">
                                <i class="fa fa-upload me-1"/>Import
                            </t>
                        </button>
                    </div>
                </t>

                <t t-if="state.result">
                    <t t-if="state.result.error">
                        <div class="alert alert-danger">
                            <i class="fa fa-exclamation-triangle me-1"/>
                            <t t-esc="state.result.error"/>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-success" t-if="state.result.created">
                            <i class="fa fa-check-circle me-1"/>
                            <strong>Import completed!</strong>
                        </div>
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <td>Serials created</td>
                                    <td class="text-end fw-bold text-success">
                                        <t t-esc="state.result.created"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Skipped (duplicates)</td>
                                    <td class="text-end fw-bold text-primary">
                                        <t t-esc="state.result.skipped"/>
                                    </td>
                                </tr>
                                <tr t-if="state.result.errors">
                                    <td>Errors</td>
                                    <td class="text-end fw-bold text-danger">
                                        <t t-esc="state.result.errors"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div t-if="state.result.warnings and state.result.warnings.length"
                             class="alert alert-warning">
                            <strong>Skipped (duplicates):</strong>
                            <ul class="mb-0 mt-1">
                                <li t-foreach="state.result.warnings" t-as="w" t-key="w_index">
                                    <t t-esc="w"/>
                                </li>
                            </ul>
                        </div>

                        <div t-if="state.result.row_errors and state.result.row_errors.length"
                             class="alert alert-danger">
                            <strong>Row errors:</strong>
                            <ul class="mb-0 mt-1">
                                <li t-foreach="state.result.row_errors" t-as="e" t-key="e_index">
                                    <t t-esc="e"/>
                                </li>
                            </ul>
                        </div>
                    </t>

                    <div class="text-end mt-3">
                        <button class="btn btn-primary" t-on-click="props.close">
                            Close
                        </button>
                    </div>
                </t>
            </div>
        </Dialog>
    </t>

</templates>
