    <t t-name="ggg_rental.DownloadProductTemplate">
        <DropdownItem onSelected.bind="onClick">
            <i class="fa fa-fw fa-download me-1"/>Download Product Template
        </DropdownItem>
    </t>

    <t t-name="ggg_rental.DownloadPricingTemplate">
        <DropdownItem onSelected.bind="onClick">
