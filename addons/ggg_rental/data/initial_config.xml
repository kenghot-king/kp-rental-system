<odoo>
<data noupdate="1">

    <!-- ============================================================ -->
    <!-- Company: Rental Settings                                      -->
    <!-- ============================================================ -->
    <record id="base.main_company" model="res.company">
        <field name="min_extra_hour">2</field>
    </record>

    <!-- ============================================================ -->
    <!-- Taxes: Created manually after Thai chart of accounts setup   -->
    <!-- See documents/deploy.md for post-install configuration       -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- Journals: Payment Methods                                     -->
    <!-- ============================================================ -->
    <record id="journal_cash" model="account.journal">
        <field name="name">Cash</field>
        <field name="type">cash</field>
        <field name="code">CASH</field>
    </record>

    <record id="journal_visa" model="account.journal">
        <field name="name">VISA</field>
        <field name="type">bank</field>
        <field name="code">VISA</field>
    </record>

    <record id="journal_master" model="account.journal">
        <field name="name">MASTER</field>
        <field name="type">bank</field>
        <field name="code">MC</field>
    </record>

    <record id="journal_promptpay" model="account.journal">
        <field name="name">QR PromptPay</field>
        <field name="type">bank</field>
        <field name="code">QR</field>
    </record>

    <record id="journal_transfer" model="account.journal">
        <field name="name">Transfer</field>
        <field name="type">bank</field>
        <field name="code">TRF</field>
    </record>

</data>
</odoo>
