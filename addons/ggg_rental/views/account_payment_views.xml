<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_rental" model="ir.ui.view">
        <field name="name">account.payment.form.rental</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <field name="memo" position="after">
                <field name="is_rental_payment" invisible="1"/>
                <field name="payment_reference"
                    string="Reference 1"
                    invisible="not is_rental_payment"/>
                <field name="payment_reference_2"
                    invisible="not is_rental_payment"/>
            </field>
        </field>
    </record>
</odoo>
