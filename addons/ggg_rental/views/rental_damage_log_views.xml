<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="rental_damage_log_view_list" model="ir.ui.view">
        <field name="name">rental.damage.log.list</field>
        <field name="model">rental.damage.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="order_id"/>
                <field name="product_id"/>
                <field name="lot_id" optional="show"/>
                <field name="damage_fee" sum="Total"/>
                <field name="reason"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="rental_damage_log_view_form" model="ir.ui.view">
        <field name="name">rental.damage.log.form</field>
        <field name="model">rental.damage.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="damage_fee"/>
                        </group>
                        <group>
                            <field name="order_id"/>
                            <field name="order_line_id"/>
                            <field name="date"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="rental_damage_log_view_search" model="ir.ui.view">
        <field name="name">rental.damage.log.search</field>
        <field name="model">rental.damage.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="order_id"/>
                <field name="reason"/>
                <separator/>
                <filter name="filter_this_month" string="This Month" domain="[('date', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%%Y-%%m-%%d'))]"/>
                <separator/>
                <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                <filter name="group_lot" string="Serial Number" context="{'group_by': 'lot_id'}"/>
                <filter name="group_order" string="Order" context="{'group_by': 'order_id'}"/>
            </search>
        </field>
    </record>

</odoo>
