<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.rental</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app
                     data-string="Rental"
                     string="Rental"
                     name="ggg_rental"
                     groups="sales_team.group_sale_manager">
                    <block title="Rental">
                        <setting name="rental_location" string="Rental Location" help="Internal stock locations for rental, damage, and inspection">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="rental_loc_id" class="col-lg-3 o_light_label"/>
                                    <field name="rental_loc_id"/>
                                </div>
                                <div class="row mt8">
                                    <label for="damage_loc_id" class="col-lg-3 o_light_label"/>
                                    <field name="damage_loc_id"/>
                                </div>
                                <div class="row mt8">
                                    <label for="inspection_loc_id" class="col-lg-3 o_light_label"/>
                                    <field name="inspection_loc_id"/>
                                </div>
                            </div>
                        </setting>
                        <setting title="Those values are applied to any new rental product and can be changed on product forms." name="rental_delay_costs" string="Default Delay Costs" help="Additional costs for late returns">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="extra_hour" class="col-lg-3 o_light_label"/>
                                    <field name="extra_hour" widget="monetary" class="col-lg-2"/>
                                </div>
                                <div class="row mt2">
                                    <label for="extra_day" class="col-lg-3 o_light_label"/>
                                    <field name="extra_day" widget="monetary" class="col-lg-2"/>
                                </div>
                                <div class="row mt2 o_light_label">
                                    <label string="Apply after" for="min_extra_hour" class="col-lg-3"/>
                                    <field name="min_extra_hour" class="col-lg-2"/>
                                    <label string="hours" for="min_extra_hour" class="col-lg-2"/>
                                </div>
                                <div class="row mt8">
                                    <label string="Product" for="extra_product" class="col-lg-3 o_light_label"/>
                                    <field
                                        name="extra_product"
                                        placeholder="Product to charge extra time"
                                        context="{'default_type': 'service'}"
                                    />
                                </div>
                                <div class="row mt8">
                                    <label string="Default Pickup Time" for="rental_pickup_time" class="col-lg-3 o_light_label"/>
                                    <field name="rental_pickup_time" widget="float_time" class="col-lg-2"/>
                                </div>
                                <div class="row mt2">
                                    <label string="Default Return Time" for="rental_return_time" class="col-lg-3 o_light_label"/>
                                    <field name="rental_return_time" widget="float_time" class="col-lg-2"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Damage">
                        <setting name="damage_product_setting" string="Damage Product" help="Service product used for damage fee charges on returns">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label string="Product" for="damage_product" class="col-lg-3 o_light_label"/>
                                    <field
                                        name="damage_product"
                                        placeholder="Product to charge damage fees"
                                        context="{'default_type': 'service'}"
                                    />
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Deposit">
                        <setting name="rental_deposit_product_setting" string="Deposit Product" help="Product used for auto-created deposit lines on rental orders">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label string="Product" for="rental_deposit_product_id" class="col-lg-3 o_light_label"/>
                                    <field
                                        name="rental_deposit_product_id"
                                        placeholder="Select a deposit product"
                                    />
                                </div>
                            </div>
                        </setting>
                        <setting name="deposit_auto_refund_setting" string="Auto Refund Deposit" help="Automatically register a refund payment when deposit credit note is created on return">
                            <field name="deposit_auto_refund"/>
                        </setting>
                    </block>
                    <block title="Pickup">
                        <setting name="require_payment_before_pickup_setting" string="Require Payment Before Pickup" help="Block the pickup process until all posted customer invoices are fully paid">
                            <field name="require_payment_before_pickup"/>
                        </setting>
                        <setting name="auto_confirm_invoice_setting" string="Auto Confirm Invoice" help="Automatically confirm (post) invoices immediately after creation from a rental order, making them ready for payment.">
                            <field name="auto_confirm_invoice"/>
                        </setting>
                    </block>
                    <block title="Rental Contract">
                        <div class="o_setting_box w-100">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane w-100">
                                <div class="o_form_label fw-bold">Contract Terms</div>
                                <div class="text-muted small mb-2">Terms and conditions printed on rental contracts</div>
                                <field name="rental_contract_terms" widget="html"
                                    options='{"toolbar": true, "resizable": true}'/>
                            </div>
                        </div>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_rental_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="view_mode">form</field>
        <field name="context">{'module' : 'ggg_rental', 'bin_size': False}</field>
    </record>

</odoo>
