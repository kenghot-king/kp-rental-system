<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Reconciliation list view ───────────────────────────────────────── -->
    <record id="rental_daily_reconciliation_view_list" model="ir.ui.view">
        <field name="name">rental.daily.reconciliation.list</field>
        <field name="model">rental.daily.reconciliation</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'draft'">
                <field name="date"/>
                <field name="cashier_id"/>
                <field name="expected_total" sum="Expected Total"/>
                <field name="actual_total" sum="Actual Total"/>
                <field name="variance_total" sum="Variance"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'draft'"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Reconciliation form view ──────────────────────────────────────── -->
    <record id="rental_daily_reconciliation_view_form" model="ir.ui.view">
        <field name="name">rental.daily.reconciliation.form</field>
        <field name="model">rental.daily.reconciliation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"
                            groups="ggg_rental.group_rental_supervisor"/>
                    <button name="action_reopen" string="Reopen"
                            type="object"
                            invisible="state != 'confirmed'"
                            groups="ggg_rental.group_rental_supervisor"/>
                    <button name="action_print_xlsx" string="Print XLSX"
                            type="object" icon="fa-file-excel-o"/>
                    <button name="action_report_reconciliation_pdf"
                            string="Print PDF"
                            type="object" icon="fa-print"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state == 'confirmed'"/>
                            <field name="cashier_id" readonly="state == 'confirmed'"/>
                        </group>
                        <group>
                            <field name="expected_total" readonly="1"/>
                            <field name="actual_total" readonly="1"/>
                            <field name="variance_total" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Supervisor Info"
                           invisible="state == 'draft' and not confirmed_by">
                        <field name="confirmed_by" readonly="1"/>
                        <field name="confirmed_at" readonly="1"/>
                        <field name="reopened_by" readonly="1"
                               invisible="not reopened_by"/>
                        <field name="reopened_at" readonly="1"
                               invisible="not reopened_at"/>
                    </group>
                    <group>
                        <field name="note" readonly="state == 'confirmed'"
                               placeholder="Optional notes..."/>
                    </group>
                    <separator string="Payment Lines"/>
                    <button name="action_rebuild_lines" string="↺ Refresh Lines"
                            type="object" class="btn-secondary mb-2"
                            invisible="state != 'draft'"
                            groups="ggg_rental.group_rental_supervisor"/>
                    <field name="line_ids" readonly="state == 'confirmed'">
                        <list editable="bottom">
                            <field name="display_method" readonly="1"/>
                            <field name="journal_id" readonly="1"/>
                            <field name="expected_amount" readonly="1"
                                   sum="Expected"/>
                            <field name="actual_amount" sum="Actual"/>
                            <field name="variance" readonly="1" sum="Variance"/>
                            <field name="actual_entered" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Reconciliation search view ────────────────────────────────────── -->
    <record id="rental_daily_reconciliation_view_search" model="ir.ui.view">
        <field name="name">rental.daily.reconciliation.search</field>
        <field name="model">rental.daily.reconciliation</field>
        <field name="arch" type="xml">
            <search>
                <field name="cashier_id"/>
                <field name="date"/>
                <separator/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <separator/>
                <filter name="has_variance" string="Has Variance"
                        domain="[('variance_total', '!=', 0)]"/>
                <separator/>
                <filter name="date_today" string="Today"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_cashier" string="Cashier"
                            context="{'group_by': 'cashier_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'date'}"/>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action: Reconciliation list ───────────────────────────────────── -->
    <record id="action_rental_daily_reconciliation" model="ir.actions.act_window">
        <field name="name">Daily Reconciliation</field>
        <field name="res_model">rental.daily.reconciliation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reconciliations yet.
            </p>
            <p>
                Create a reconciliation record for each cashier's daily collection,
                enter actual amounts per payment method, then confirm to lock.
            </p>
        </field>
    </record>

    <!-- ── Server action: Bulk confirm ───────────────────────────────────── -->
    <record id="action_rental_reconciliation_confirm_multi" model="ir.actions.server">
        <field name="name">Confirm Selected</field>
        <field name="model_id" ref="model_rental_daily_reconciliation"/>
        <field name="binding_model_id" ref="model_rental_daily_reconciliation"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_confirm_multi()</field>
    </record>

    <!-- ── Needs-reconciliation view ─────────────────────────────────────── -->
    <record id="rental_daily_reconciliation_needed_view_list" model="ir.ui.view">
        <field name="name">rental.daily.reconciliation.needed.list</field>
        <field name="model">rental.daily.reconciliation.needed</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="payment_date"/>
                <field name="cashier_id"/>
                <field name="payment_count"/>
                <field name="total_amount"/>
                <button name="action_create_reconciliation"
                        string="Create Reconciliation"
                        type="object" class="btn-primary"/>
            </list>
        </field>
    </record>

    <record id="rental_daily_reconciliation_needed_view_search" model="ir.ui.view">
        <field name="name">rental.daily.reconciliation.needed.search</field>
        <field name="model">rental.daily.reconciliation.needed</field>
        <field name="arch" type="xml">
            <search>
                <field name="cashier_id"/>
                <field name="payment_date"/>
                <group>
                    <filter name="group_cashier" string="Cashier"
                            context="{'group_by': 'cashier_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'payment_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_rental_daily_reconciliation_needed" model="ir.actions.act_window">
        <field name="name">Needs Reconciliation</field>
        <field name="res_model">rental.daily.reconciliation.needed</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                All cashiers' days are reconciled!
            </p>
        </field>
    </record>

    <!-- ── Inherit res.users form: Rental Supervisor checkbox ───────────── -->
    <record id="view_users_form_rental_supervisor" model="ir.ui.view">
        <field name="name">res.users.form.rental.supervisor</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="inside">
                <group string="Rental" invisible="share">
                    <field name="is_rental_supervisor" string="Rental Supervisor"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ── Inherit account.payment form: show reconciliation_id ──────────── -->
    <record id="view_account_payment_form_recon" model="ir.ui.view">
        <field name="name">account.payment.form.reconciliation</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='cashier_id']" position="after">
                <field name="reconciliation_id" readonly="1"
                       invisible="not reconciliation_id"/>
            </xpath>
        </field>
    </record>

    <!-- Menus moved to sale_renting_menus.xml to ensure correct load order -->

    <menuitem id="menu_rental_reconciliation_needed"
              name="Needs Reconciliation"
              parent="menu_rental_reconciliation_root"
              action="action_rental_daily_reconciliation_needed"
              sequence="20"
              groups="ggg_rental.group_rental_supervisor"/>


</odoo>
