<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="qa_scenario_log_list_view" model="ir.ui.view">
        <field name="name">qa.scenario.log.list</field>
        <field name="model">qa.scenario.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="order_id"/>
                <field name="scenario_id"/>
                <field name="field_changed" string="Field"/>
                <field name="original_value" string="Original Date"/>
                <field name="new_value" string="Mutated Date"/>
                <field name="applied_by"/>
                <field name="applied_at"/>
                <field name="reverted"/>
            </list>
        </field>
    </record>

    <record id="action_qa_scenario_log" model="ir.actions.act_window">
        <field name="name">QA Logs</field>
        <field name="res_model">qa.scenario.log</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No mutations logged yet. Apply a QA scenario to see entries here.
            </p>
        </field>
    </record>

</odoo>
