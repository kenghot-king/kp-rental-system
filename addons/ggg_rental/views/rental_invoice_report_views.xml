<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── By Item: search view (inherits base to avoid standalone validation) -->
    <record id="view_rental_invoice_line_search" model="ir.ui.view">
        <field name="name">rental.invoice.line.search</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="rental_paid" string="Paid"
                    domain="[('move_id.payment_state', '=', 'paid')]"/>
                <filter name="rental_in_payment" string="In Payment"
                    domain="[('move_id.payment_state', '=', 'in_payment')]"/>
                <filter name="rental_not_paid" string="Not Paid"
                    domain="[('move_id.payment_state', '=', 'not_paid')]"/>
                <filter name="rental_partial" string="Partial"
                    domain="[('move_id.payment_state', '=', 'partial')]"/>
            </xpath>
        </field>
    </record>

    <!-- ── By Item: list view ─────────────────────────────────────────────── -->
    <record id="view_rental_invoice_line_list" model="ir.ui.view">
        <field name="name">rental.invoice.line.list</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list string="By Item" create="false" edit="false" delete="false"
                  default_order="date desc, move_id desc, id">
                <field name="move_id" string="Invoice" optional="show"/>
                <field name="date" string="Invoice Date" optional="show"/>
                <field name="date_maturity" string="Due Date" optional="show"/>
                <field name="partner_id" string="Customer" optional="show"/>
                <field name="product_id" optional="show"/>
                <field name="name" string="Description" optional="hide"/>
                <field name="quantity" optional="show"/>
                <field name="product_uom_id" string="Unit" optional="hide"/>
                <field name="price_unit" string="Unit Price" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="price_subtotal" string="Subtotal"
                       sum="Total" optional="show"/>
                <field name="tax_amount" string="Tax"
                       sum="Total Tax" optional="show"/>
                <field name="parent_state" string="Status"
                       widget="badge"
                       decoration-success="parent_state == 'posted'"
                       decoration-warning="parent_state == 'draft'"
                       decoration-danger="parent_state == 'cancel'"
                       optional="show"/>
                <field name="invoice_payment_state" string="Payment Status"
                       widget="badge"
                       decoration-success="invoice_payment_state in ('paid', 'in_payment')"
                       decoration-warning="invoice_payment_state == 'partial'"
                       decoration-danger="invoice_payment_state == 'not_paid'"
                       optional="show"/>
            </list>
        </field>
    </record>

    <!-- ── By Item: action ────────────────────────────────────────────────── -->
    <record id="action_rental_invoice_by_item" model="ir.actions.act_window">
        <field name="name">By Item</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list</field>
        <field name="domain">[('move_id.move_type', '=', 'out_invoice'), ('display_type', '=', 'product')]</field>
        <field name="context">{}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_rental_invoice_line_list')}),
        ]"/>
    </record>

</odoo>
