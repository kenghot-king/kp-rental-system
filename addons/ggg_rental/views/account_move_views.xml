<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Deposit invoice: On Hold badge + Unhold/Forfeit buttons + smart button -->
    <record id="view_account_move_hold_payment" model="ir.ui.view">
        <field name="name">account.move.hold.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Invisible carrier fields -->
            <xpath expr="//sheet" position="before">
                <field name="deposit_hold_state" invisible="1"/>
                <field name="deposit_hold_payment_ids" invisible="1"/>
                <field name="is_deposit_invoice" invisible="1"/>
                <field name="is_picked_up" invisible="1"/>
            </xpath>

            <!-- Smart button: hold payments -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_hold_payments"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-credit-card"
                        invisible="not deposit_hold_payment_ids">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="deposit_hold_payment_ids" widget="many2many_tags" no_open="1" invisible="1"/>
                        </span>
                        <span class="o_stat_text">Hold</span>
                    </div>
                </button>
            </xpath>

            <!-- On Hold badge in status bar -->
            <xpath expr="//field[@name='payment_state']" position="after">
                <widget name="web_ribbon"
                        title="On Hold"
                        bg_color="bg-warning"
                        invisible="deposit_hold_state != 'hold'"/>
            </xpath>

            <!-- Unhold and Forfeit buttons in header (only after item is picked up) -->
            <xpath expr="//div[@name='button_box']" position="before">
                <button name="action_unhold"
                        string="Unhold"
                        type="object"
                        class="btn-secondary"
                        invisible="deposit_hold_state != 'hold' or not is_picked_up"
                        confirm="Release the credit hold? The deposit invoice will return to unpaid."/>
                <button name="action_forfeit"
                        string="Forfeit"
                        type="object"
                        class="btn-danger"
                        invisible="deposit_hold_state != 'hold' or not is_picked_up"/>
                <button name="action_print_deposit_certificate"
                        string="Print Deposit Certificate"
                        type="object"
                        class="btn-secondary"
                        invisible="not is_deposit_invoice or deposit_hold_state != 'hold'"/>
            </xpath>

        </field>
    </record>
</odoo>
